# ============================================================
# COMUNIDADE VIEWRS - VARIÁVEIS DE AMBIENTE
# ============================================================
# NUNCA commite o arquivo .env real! Use este .env.example como template.

# --- Servidor ---
NODE_ENV=development
PORT=3000
API_VERSION=v1

# --- Banco de Dados ---
MONGODB_URI=mongodb://localhost:27017/comunidade_viewrs
MONGODB_URI_TEST=mongodb://localhost:27017/comunidade_viewrs_test

# --- JWT (Tokens de Autenticação) ---
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=SUBSTITUA_POR_STRING_ALEATORIA_LONGA_E_SEGURA_MINIMO_64_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=SUBSTITUA_POR_OUTRA_STRING_ALEATORIA_DIFERENTE_DA_ACIMA
JWT_REFRESH_EXPIRES_IN=30d

# --- Segurança ---
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:5500,https://comunidadeviewrs.com.br
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# --- Email (para recuperação de senha) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua_senha_de_app

# --- Logs ---
LOG_LEVEL=info
LOG_FILE=logs/app.log

# --- Mercado Pago ---
# Copie em: mercadopago.com.br/developers -> Suas integrações -> Credenciais de produção
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-000000000
# URL onde o MP vai enviar os webhooks (seu backend no Railway)
MP_WEBHOOK_URL=https://seuapp.railway.app/api/v1/payments/webhook
